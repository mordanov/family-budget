FROM node:20-alpine AS builder
WORKDIR /app

ARG VITE_API_URL=/api/v1
ENV VITE_API_URL=$VITE_API_URL

ARG VITE_KITCHEN_API_URL=
ENV VITE_KITCHEN_API_URL=$VITE_KITCHEN_API_URL

ARG VITE_KITCHEN_SERVICE_USER=
ENV VITE_KITCHEN_SERVICE_USER=$VITE_KITCHEN_SERVICE_USER

ARG VITE_KITCHEN_SERVICE_PASSWORD=
ENV VITE_KITCHEN_SERVICE_PASSWORD=$VITE_KITCHEN_SERVICE_PASSWORD

COPY package*.json ./
RUN npm install

COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx-spa.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
