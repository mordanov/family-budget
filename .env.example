# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://budget_user:your_password@db:5432/family_budget
DB_MIN_CONNECTIONS=1
DB_MAX_CONNECTIONS=10
DB_COMMAND_TIMEOUT=60

# ── Application ────────────────────────────────────────────────────────────
APP_NAME=Family Budget
APP_HOST=0.0.0.0
APP_PORT=8501
DEBUG=false

# ── File storage ───────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# ── Security ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-32-char-string

# ── Default settings ───────────────────────────────────────────────────────
DEFAULT_CURRENCY=USD

# ── Test database (for CI/CD) ──────────────────────────────────────────────
TEST_DATABASE_URL=postgresql://budget_user:your_password@localhost:5432/family_budget_test
